# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==============================================================================
# PRODUCTION SECURITY & HARDENING ENVIRONMENT CONFIGURATIONS
# ==============================================================================

# Node Environment Mode
NODE_ENV="production"

# Database Connection (e.g., PostgreSQL for Cloud SQL)
DATABASE_URL="postgresql://db_user:db_secure_password@127.0.0.1:5432/bomaflow_db?sslmode=require"

# JWT Secret Token for Authenticated Session Verification (min 32 characters)
JWT_SECRET="super_secure_cryptographic_signing_key_for_sessions_minimum_32_chars"

# Client Session Expiration Limit (e.g. 2 hours in ms)
SESSION_EXPIRY_MS="7200000"

# CORS Security Allowed Origins (comma separated list)
CORS_ALLOWED_ORIGINS="https://bomaflow.co.ke,https://ais-dev-xgby2q3kr4u56hlfhfzucx-603191559000.europe-west2.run.app"

# Rate Limiting Configuration Thresholds
RATE_LIMIT_WINDOW_MS="900000" # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"   # Max 100 requests per IP per window

# Secure Cookie Settings
COOKIE_SECURE="true"
COOKIE_SAME_SITE="Strict"

# Helmet Content-Security-Policy (CSP) Override Controls
CSP_REPORT_ONLY="false"

